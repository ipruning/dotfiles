{
  "agent_buffer_font_size": 11.0,
  "agent_ui_font_size": 13.0,
  "lsp": {
    "markdownlint": {
      "settings": {
        "MD013": false,
      },
    },
  },
  "edit_predictions": {
    "provider": "zed",
  },
  "agent_servers": {
    "codex-acp": {
      "type": "registry",
      "default_mode": "full-access",
      "favorite_models": ["gpt-5.2/xhigh"],
    },
    "claude-acp": {
      "type": "registry",
      "favorite_models": ["opus"],
    },
  },
  "agent": {
    "tool_permissions": {
      "default": "allow",
    },
    "default_model": {
      "model": "gpt-5",
      "provider": "openai",
    },
    "default_profile": "write",
    "play_sound_when_agent_done": "always",
    "use_modifier_to_send": true,
  },
  "autosave": "on_focus_change",
  "buffer_font_fallbacks": ["Maple Mono NF CN"],
  "buffer_font_family": "MonoLisa",
  "buffer_font_size": 11.0,
  "buffer_font_weight": 500,
  "buffer_line_height": {
    "custom": 1.5,
  },
  "collaboration_panel": {
    "dock": "right",
  },
  "cursor_blink": false,
  "file_types": {
    "Dockerfile": ["Dockerfile", "Dockerfile.*"],
    "JSON": ["json"],
    "JSONC": ["**/.zed/**/*.json", "**/zed/**/*.json", "**/.vscode/**/*.json"],
  },
  "format_on_save": "on",
  "git_panel": {
    "dock": "right",
  },
  "icon_theme": "Catppuccin Mocha",
  "indent_guides": {
    "coloring": "indent_aware",
    "enabled": true,
  },
  "inlay_hints": {
    "enabled": true,
  },
  "languages": {
    "Python": {
      "language_servers": ["ty", "ruff", "!basedpyright", "!pylsp"],
      "format_on_save": "on",
      "formatter": [{ "language_server": { "name": "ruff" } }],
    },
  },
  "outline_panel": {
    "dock": "right",
  },
  "preferred_line_length": 120,
  "project_panel": {
    "dock": "left",
  },
  "restore_on_startup": "last_session",
  "scroll_beyond_last_line": "off",
  "scrollbar": {
    "show": "never",
  },
  "show_edit_predictions": true,
  "tabs": {
    "file_icons": true,
    "git_status": true,
    "show_diagnostics": "errors",
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "terminal": {
    "button": false,
    "env": {
      "EDITOR": "zed --wait",
      "VISUAL": "zed --wait",
    },
    "font_family": "MonoLisa",
    "font_size": 11.0,
    "font_weight": 500,
    "line_height": {
      "custom": 1.5,
    },
    "toolbar": {
      "breadcrumbs": false,
    },
  },
  "theme": "Catppuccin Mocha",
  "ui_font_family": "MonoLisa",
  "ui_font_size": 13.0,
  "ui_font_weight": 500,
  "vim": {
    "highlight_on_yank_duration": 250,
    "toggle_relative_line_numbers": true,
    "use_smartcase_find": true,
    "use_system_clipboard": "on_yank",
  },
  "vim_mode": true,
}
