[
  {
    "label": "zed Paste Img",
    "command": "~/dotfiles/modules/bin/zed-image-paste",
    "env": {
      "IMG_SAVE_PATH": "assets",
    },
    "use_new_terminal": false,
    "allow_concurrent_runs": true,
    "reveal": "never",
    "hide": "always",
    "shell": "system",
  },
  {
    "label": "live_grep",
    "command": "selection=$(tv text); [ -n \"$selection\" ] && zed \"$selection\"",
    "hide": "always",
    "show_summary": false,
    "show_command": false,
    "allow_concurrent_runs": true,
    "use_new_terminal": true,
    "shell": {
      "with_arguments": {
        "program": "/bin/bash",
        "args": ["--noediting", "--norc", "--noprofile"],
      },
    },
  },
  {
    "label": "file_finder",
    "command": "cwd=$(pwd -P); [ \"$cwd\" = \"/\" ] && exit 0; selection=$(tv hidden-files); [ -n \"$selection\" ] && zed \"$selection\"",
    "hide": "always",
    "show_summary": false,
    "show_command": false,
    "allow_concurrent_runs": true,
    "use_new_terminal": true,
    "shell": {
      "with_arguments": {
        "program": "/bin/bash",
        "args": ["--noediting", "--norc", "--noprofile"],
      },
    },
  },
  {
    "label": "file_finder_modified",
    "command": "cwd=$(pwd -P); [ \"$cwd\" = \"/\" ] && exit 0; selection=$(tv modified-files); [ -n \"$selection\" ] && zed \"$selection\"",
    "hide": "always",
    "show_summary": false,
    "show_command": false,
    "allow_concurrent_runs": true,
    "use_new_terminal": true,
    "shell": {
      "with_arguments": {
        "program": "/bin/bash",
        "args": ["--noediting", "--norc", "--noprofile"],
      },
    },
  },
  {
    "label": "project_finder",
    "command": "selection=$(tv git-repos); [ -n \"$selection\" ] && zed \"$selection\"",
    "hide": "always",
    "show_summary": false,
    "show_command": false,
    "allow_concurrent_runs": true,
    "use_new_terminal": true,
    "shell": {
      "with_arguments": {
        "program": "/bin/bash",
        "args": ["--noediting", "--norc", "--noprofile"],
      },
    },
  },
  {
    "label": "yazi",
    "command": "yazi",
    "hide": "always",
    "show_summary": false,
    "show_command": false,
    "allow_concurrent_runs": true,
    "use_new_terminal": true,
    "shell": {
      "with_arguments": {
        "program": "/bin/bash",
        "args": ["--noediting", "--norc", "--noprofile"],
      },
    },
    "env": {
      "EDITOR": "zed --wait",
      "VISUAL": "zed --wait",
    },
  },
  {
    "label": "yazi_with_file",
    "command": "yazi",
    "args": ["$ZED_FILE"],
    "hide": "always",
    "show_summary": false,
    "show_command": false,
    "allow_concurrent_runs": true,
    "use_new_terminal": true,
    "shell": { "with_arguments": { "program": "/bin/bash", "args": ["--noediting", "--norc", "--noprofile"] } },
    "env": { "EDITOR": "zed --wait", "VISUAL": "zed --wait" },
  },
  {
    "label": "lazygit",
    "command": "~/.local/share/mise/shims/lazygit",
    "hide": "always",
    "show_summary": false,
    "show_command": false,
    "allow_concurrent_runs": true,
    "use_new_terminal": true,
    "shell": {
      "with_arguments": {
        "program": "/bin/bash",
        "args": ["--noediting", "--norc", "--noprofile"],
      },
    },
  },
  {
    "label": "lazydocker",
    "command": "~/.local/share/mise/shims/lazydocker",
    "hide": "always",
    "show_summary": false,
    "show_command": false,
    "allow_concurrent_runs": true,
    "use_new_terminal": true,
    "shell": {
      "with_arguments": {
        "program": "/bin/bash",
        "args": ["--noediting", "--norc", "--noprofile"],
      },
    },
  },
  {
    "label": "gitu",
    "command": "gitu",
    "hide": "always",
    "show_summary": false,
    "show_command": false,
    "allow_concurrent_runs": true,
    "use_new_terminal": true,
    "shell": {
      "with_arguments": {
        "program": "/bin/bash",
        "args": ["--noediting", "--norc", "--noprofile"],
      },
    },
  },
  {
    "label": "amp-tmux",
    "command": "amp-tmux",
    "hide": "always",
    "show_summary": false,
    "show_command": false,
    "allow_concurrent_runs": true,
    "use_new_terminal": true,
  },
  {
    "label": "tmux",
    "command": "session_name=zed-$(basename \"$(pwd -P)\"); tmux new-session -A -s \"$session_name\"",
    "hide": "always",
    "show_summary": false,
    "show_command": false,
    "allow_concurrent_runs": true,
    "use_new_terminal": true,
    "shell": {
      "with_arguments": {
        "program": "/bin/bash",
        "args": ["--noediting", "--norc", "--noprofile"],
      },
    },
  },
  {
    "label": "zellij",
    "command": "session_name=zed-$(basename \"$(pwd -P)\"); zellij attach --create \"$session_name\"",
    "hide": "always",
    "show_summary": false,
    "show_command": false,
    "allow_concurrent_runs": true,
    "use_new_terminal": true,
    "shell": {
      "with_arguments": {
        "program": "/bin/bash",
        "args": ["--noediting", "--norc", "--noprofile"],
      },
    },
  },
  {
    "label": "run",
    "command": "file=\"$ZED_FILE\"; ext=\"${file##*.}\"; case \"$ext\" in bash) exec bash \"$file\" ;; sh) exec sh \"$file\" ;; py) exec mise exec -- uv run \"$file\" ;; js|jsx|mjs|cjs|ts|tsx) exec mise exec -- bun run \"$file\" ;; *) echo \"Unsupported file type: .$ext\" >&2; exit 2 ;; esac",
    "allow_concurrent_runs": true,
    "use_new_terminal": true,
    "shell": {
      "with_arguments": {
        "program": "/bin/bash",
        "args": ["--noediting", "--norc", "--noprofile"],
      },
    },
  },
]
