#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd -- "$script_dir/../.." && pwd)"
impl="$repo_root/modules/libexec/macos-session-health.py"

uv_bin="$(command -v uv || true)"
if [ -z "$uv_bin" ] || [ ! -x "$uv_bin" ]; then
  for candidate in \
    "$HOME/.local/share/mise/shims/uv" \
    "$HOME/.local/bin/uv" \
    /opt/homebrew/bin/uv \
    /usr/local/bin/uv; do
    if [ -x "$candidate" ]; then
      uv_bin="$candidate"
      break
    fi
  done
fi

if [ -z "$uv_bin" ] || [ ! -x "$uv_bin" ]; then
  echo "macos-session-health: uv is required" >&2
  exit 127
fi

exec "$uv_bin" run --script "$impl" "$@"
