#!/usr/bin/env bash

set -euo pipefail
file="$(mktemp)"
echo "Editing $file"

candidates=()
[[ -n "${VISUAL:-}" ]] && candidates+=("$VISUAL")
[[ -n "${EDITOR:-}" && "${EDITOR:-}" != "${VISUAL:-}" ]] && candidates+=("$EDITOR")
candidates+=(
  "cursor --wait"
  "code -w"
  "nvim"
  "vim"
  "vi"
)

for candidate in "${candidates[@]}"; do
  read -r -a cmd <<< "$candidate"
  exe="${cmd[0]}"

  if [[ "$exe" == /* && ! -x "$exe" ]]; then
    if resolved="$(command -v "$(basename "$exe")" 2>/dev/null)"; then
      cmd[0]="$resolved"
    else
      continue
    fi
  elif ! command -v "$exe" >/dev/null 2>&1; then
    continue
  fi

  exec "${cmd[@]}" "$file"
done

# `vi` is in the candidate list above, so this is only reached if even
# /usr/bin/vi is missing — then there is nothing left to fall back to.
echo "scratch: no usable editor found ($VISUAL/$EDITOR/cursor/code/nvim/vim/vi)" >&2
exit 1
