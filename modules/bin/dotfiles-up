#!/usr/bin/env bash

set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd -- "$script_dir/../.." && pwd)"

# shellcheck source=modules/bin/_lib/task-lib.sh
source "$repo_root/modules/bin/_lib/task-lib.sh"

run_update() {
  local title="$1" timeout_seconds="$2" output_mode="$3"
  shift 3

  SECONDS=0
  dotfiles_log info "${title}..."
  if [ "$output_mode" = "quiet" ]; then
    if dotfiles_run_visible "${title}..." "$timeout_seconds" "$@"; then
      dotfiles_log info "${title} done in ${SECONDS}s"
      return 0
    else
      local exit_status=$?
      dotfiles_log error "${title} failed after ${SECONDS}s (exit ${exit_status})"
      return "$exit_status"
    fi
  else
    if dotfiles_run_with_timeout "$timeout_seconds" "$@"; then
      dotfiles_log info "${title} done in ${SECONDS}s"
      return 0
    else
      local exit_status=$?
      dotfiles_log error "${title} failed after ${SECONDS}s (exit ${exit_status})"
      return "$exit_status"
    fi
  fi
}

run_if_available() {
  local binary="$1" title="$2" timeout_seconds="$3" output_mode="$4"
  shift 4

  command -v "$binary" >/dev/null 2>&1 || return 0
  run_update "$title" "$timeout_seconds" "$output_mode" "$@"
}

run_if_available_or_warn() {
  local binary="$1" title="$2" install_hint="$3" timeout_seconds="$4" output_mode="$5"
  shift 5

  if command -v "$binary" >/dev/null 2>&1; then
    run_update "$title" "$timeout_seconds" "$output_mode" "$@"
  else
    dotfiles_log warn "$binary not found. Install: $install_hint"
  fi
}

# Homebrew can upgrade CLIs used below, so run it before tool-specific updates.
if command -v brew >/dev/null 2>&1; then
  run_update "Updating Homebrew metadata" "${DOTFILES_UP_HOMEBREW_TIMEOUT:-900}" visible brew update
  run_update "Upgrading Homebrew packages" "${DOTFILES_UP_HOMEBREW_TIMEOUT:-900}" visible brew upgrade
  run_update "Cleaning Homebrew cache" "${DOTFILES_UP_HOMEBREW_TIMEOUT:-900}" visible brew cleanup
  run_update "Removing unused Homebrew packages" "${DOTFILES_UP_HOMEBREW_TIMEOUT:-900}" visible brew autoremove
fi

if command -v mise >/dev/null 2>&1; then
  run_update "Updating mise tools" "${DOTFILES_UP_MISE_TIMEOUT:-600}" visible mise upgrade --bump -C "$HOME"
  run_update "Pruning mise installs" "${DOTFILES_UP_MISE_TIMEOUT:-300}" quiet mise prune --yes
  run_update "Refreshing mise shims" "${DOTFILES_UP_MISE_TIMEOUT:-120}" quiet mise reshim
fi

run_if_available gh "Updating GitHub CLI extensions" "${DOTFILES_UP_COMMAND_TIMEOUT:-300}" visible gh extension upgrade --all
run_if_available tldr "Updating tldr pages" "${DOTFILES_UP_COMMAND_TIMEOUT:-300}" quiet tldr --update
run_if_available ya "Updating ya packages" "${DOTFILES_UP_COMMAND_TIMEOUT:-300}" visible ya pkg upgrade

# curl -fsSL https://sprites.dev/install.sh | sh
run_if_available_or_warn \
  sprite "Checking Sprite updates" \
  "curl -fsSL https://sprites.dev/install.sh | sh" \
  "${DOTFILES_UP_COMMAND_TIMEOUT:-300}" visible \
  sprite upgrade --check

# curl -fsSL https://ampcode.com/install.sh | bash
run_if_available_or_warn \
  amp "Updating Amp Code" \
  "curl -fsSL https://ampcode.com/install.sh | bash" \
  "${DOTFILES_UP_COMMAND_TIMEOUT:-300}" visible \
  amp update

# curl -fsSL https://raw.githubusercontent.com/tigrisdata/cli/main/scripts/install.sh | sh
run_if_available_or_warn \
  tigris "Updating Tigris" \
  "curl -fsSL https://raw.githubusercontent.com/tigrisdata/cli/main/scripts/install.sh | sh" \
  "${DOTFILES_UP_COMMAND_TIMEOUT:-300}" visible \
  tigris update

# Skillshare is refreshed by dotfiles-sync.
run_if_available_or_warn \
  pi "Updating Pi Plugin" \
  "brew install pi-coding-agent" \
  "${DOTFILES_UP_COMMAND_TIMEOUT:-300}" visible \
  pi update --extensions

# Mackup backup is handled by dotfiles-backup.
