#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.13"
# dependencies = [
#     "rich>=15.0.0",
#     "ruamel.yaml>=0.19.1",
#     "typer>=0.24.2",
# ]
# ///
# NOTE: ruamel.yaml is still needed for _set_source() (config write).
# No `skillshare config set` command exists yet.
"""Skillshare source switcher — manage multiple skillshare source directories."""

from __future__ import annotations

import json
import os
import platform
import re
import shutil
import subprocess
import sys
from pathlib import Path, PurePosixPath

if platform.system() == "Windows":
    print("ss: Windows is not supported", file=sys.stderr)
    sys.exit(1)

from ruamel.yaml import YAML

import typer
from rich.console import Console
from rich.text import Text

app = typer.Typer(help="Skillshare source switcher.", no_args_is_help=True)
console = Console()

def _config_path() -> Path:
    """Mirror Go's ConfigPath() for config writes (used by _set_source only)."""
    if p := os.environ.get("SKILLSHARE_CONFIG"):
        return Path(p)
    base = Path(os.environ.get("XDG_CONFIG_HOME", Path.home() / ".config"))
    return base / "skillshare" / "config.yaml"


SKILLSHARE_CFG = _config_path()
SOURCES_CFG = SKILLSHARE_CFG.parent / "sources.json"

_yaml = YAML()
_yaml.preserve_quotes = True


def _load_sources() -> dict[str, str]:
    if not SOURCES_CFG.exists():
        return {}
    data = json.loads(SOURCES_CFG.read_text()) or {}
    return {k: str(Path(v).expanduser()) for k, v in data.items()}


def _save_sources(sources: dict[str, str]) -> None:
    SOURCES_CFG.parent.mkdir(parents=True, exist_ok=True)
    SOURCES_CFG.write_text(json.dumps(sources, indent=2) + "\n")


def _skillshare_json(*args: str) -> dict | list:
    """Run a skillshare command with --global --json and return parsed output."""
    result = subprocess.run(
        ["skillshare", *args, "--global", "--json"],
        capture_output=True, text=True,
    )
    if result.returncode != 0:
        console.print(f"[red]skillshare {' '.join(args)} failed[/red]")
        if result.stderr.strip():
            console.print(Text(result.stderr.strip(), style="dim"))
        raise typer.Exit(1)
    return json.loads(result.stdout)


def _current_source() -> str:
    data = _skillshare_json("status")
    raw = data.get("source", {}).get("path", "")
    if not raw:
        console.print("[red]skillshare config has no source[/red]")
        raise typer.Exit(1)
    return str(Path(raw).expanduser()).rstrip("/")


def _set_source(path: str) -> None:
    data = _yaml.load(SKILLSHARE_CFG)
    data["source"] = path
    _yaml.dump(data, SKILLSHARE_CFG)


def _resolve_name(sources: dict[str, str], current: str) -> str | None:
    return next((k for k, v in sources.items() if v == current), None)


def _pick_other(sources: dict[str, str], current: str) -> str | None:
    others = {k: v for k, v in sources.items() if v != current}
    if not others:
        return None
    if len(others) == 1:
        return next(iter(others))
    names = list(others.keys())
    for i, name in enumerate(names, 1):
        console.print(
            Text.assemble(f"  {i}) ", (name, "bold"), "  ", (others[name], "dim"))
        )
    choice = console.input("[bold]Switch to:[/bold] ").strip()
    if choice.isdigit() and 1 <= int(choice) <= len(names):
        return names[int(choice) - 1]
    if choice in others:
        return choice
    return None


@app.command(name="list")
def list_sources():
    """List all registered sources."""
    current = _current_source()
    sources = _load_sources()
    if not sources:
        console.print(
            "[dim]No sources registered. Use [bold]ss add <name> <path>[/bold] to add one.[/dim]"
        )
        return
    for name, path in sources.items():
        active = path == current
        marker = "*" if active else " "
        style = "bold" if active else ""
        console.print(Text.assemble(f"  {marker} ", (name, style), "  ", (path, "dim")))


@app.command()
def switch(name: str | None = typer.Argument(None)):
    """Switch active source: auto-pick the other when 2 sources total; prompt otherwise."""
    sources = _load_sources()
    if not sources:
        console.print("[dim]No sources registered.[/dim]")
        raise typer.Exit(1)
    current = _current_source()
    if name is None:
        name = _pick_other(sources, current)
        if name is None:
            return
    if name not in sources:
        console.print(Text.assemble(("Source not found: ", "red"), name))
        console.print(Text(f"Available: {', '.join(sources)}", style="dim"))
        raise typer.Exit(1)
    if sources[name] == current:
        console.print(Text.assemble("Already on ", (name, "bold")))
    else:
        _set_source(sources[name])
        console.print(
            Text.assemble(
                ("✓ ", "green"), "Switched to ", (name, "bold"), f" → {sources[name]}"
            )
        )


@app.command()
def add(name: str, path: str):
    """Register a new source."""
    resolved = str(Path(path).expanduser().resolve())
    if not Path(resolved).is_dir():
        console.print(Text.assemble(("Directory not found: ", "red"), resolved))
        raise typer.Exit(1)
    sources = _load_sources()
    sources[name] = resolved
    _save_sources(sources)
    console.print(
        Text.assemble(("✓ ", "green"), "Added ", (name, "bold"), f" → {resolved}")
    )


@app.command(name="rm")
def remove(name: str):
    """Unregister a source."""
    sources = _load_sources()
    if name not in sources:
        console.print(Text.assemble(("Source not found: ", "red"), name))
        raise typer.Exit(1)
    del sources[name]
    _save_sources(sources)
    console.print(Text.assemble(("✓ ", "green"), "Removed ", (name, "bold")))


@app.command(name="exec")
def exec_cmd(name: str, cmd: list[str]):
    """Run a command with a temporary source, then restore.

    Example: ss exec <source-name> -- skillshare install foo --track
    """
    sources = _load_sources()
    if name not in sources:
        console.print(Text.assemble(("Source not found: ", "red"), name))
        raise typer.Exit(1)
    orig = _current_source()
    _set_source(sources[name])
    try:
        result = subprocess.run(cmd)
        raise typer.Exit(result.returncode)
    finally:
        _set_source(orig)


def _parse_skill_name(name: str) -> tuple[str, str | None]:
    """Split 'dir/skill' into (skill, into) or (skill, None)."""
    p = PurePosixPath(name)
    into = str(p.parent) if p.parent != PurePosixPath(".") else None
    return p.name, into


def _build_rel(name: str, into: str | None) -> str:
    return f"{into}/{name}" if into else name


_VALID_NAME = re.compile(r"^[a-zA-Z0-9][a-zA-Z0-9_-]*$")


def _validate_name(name: str) -> str | None:
    """Return error message if name is invalid, else None."""
    if not _VALID_NAME.match(name):
        return "must start with letter/number, contain only [a-zA-Z0-9_-]"
    if len(name) > 64:
        return "max 64 characters"
    if name == "agents":
        return "'agents' is a reserved name"
    return None


@app.command()
def rename(old: str, new: str):
    """Rename an installed skill: uninstall + reinstall with a new name."""

    # --- validate new name and --into segments ---
    new_name, new_into = _parse_skill_name(new)
    if err := _validate_name(new_name):
        console.print(Text.assemble(("Invalid skill name: ", "red"), (new_name, "bold"), f"\n{err}"))
        raise typer.Exit(1)
    if new_into:
        for seg in PurePosixPath(new_into).parts:
            if seg in (".", "..") or not _VALID_NAME.match(seg):
                console.print(Text.assemble(("Invalid --into segment: ", "red"), (seg, "bold")))
                raise typer.Exit(1)

    # --- load skill list via CLI ---
    source_dir = Path(_current_source())
    items = _skillshare_json("list")
    skills_by_rel: dict[str, dict] = {}
    for item in items:
        if item.get("kind", "skill") == "skill":
            skills_by_rel[item["relPath"]] = item

    # --- resolve old name (exact relPath match, then basename fallback) ---
    entry: dict | None = skills_by_rel.get(old)
    entry_key = old if entry else None
    if entry is None:
        matches = {k: v for k, v in skills_by_rel.items() if PurePosixPath(k).name == old}
        if len(matches) == 1:
            entry_key, entry = next(iter(matches.items()))
        elif len(matches) > 1:
            console.print(Text.assemble(("Ambiguous name: ", "red"), (old, "bold")))
            for m in sorted(matches):
                console.print(Text(f"  {m}", style="dim"))
            raise typer.Exit(1)

    if entry is None or entry_key is None:
        console.print(Text.assemble(("Skill not found: ", "red"), (old, "bold")))
        available = sorted(skills_by_rel.keys())
        if available:
            console.print(Text(f"Available: {', '.join(available)}", style="dim"))
        raise typer.Exit(1)

    if entry.get("repoName"):
        console.print(Text.assemble(
            ("Cannot rename tracked repo skill: ", "red"), (entry_key, "bold"),
            ("\nUse 'skillshare uninstall' on the tracked repo instead.", "dim"),
        ))
        raise typer.Exit(1)

    # --- derive canonical current path ---
    cur_name, cur_into = _parse_skill_name(entry_key)
    current_rel = _build_rel(cur_name, cur_into)
    target_rel = _build_rel(new_name, new_into)

    # --- preflight: no-op check ---
    if current_rel == target_rel:
        console.print("[yellow]Old and new resolve to the same path; nothing to do.[/yellow]")
        raise typer.Exit(0)

    # --- preflight: target already exists ---
    target_path = source_dir / Path(*PurePosixPath(target_rel).parts)
    if target_path.exists() or target_rel in skills_by_rel:
        console.print(Text.assemble(("Target already exists: ", "red"), (target_rel, "bold")))
        raise typer.Exit(1)

    install_url = entry.get("source", "")
    if not install_url:
        console.print(Text.assemble(("No source recorded for: ", "red"), (current_rel, "bold")))
        raise typer.Exit(1)

    console.print(Text.assemble(
        ("Renaming ", ""), (current_rel, "bold"), " → ", (target_rel, "bold"),
        ("\n  source: ", "dim"), (install_url, "dim"),
    ))

    # --- uninstall ---
    r1 = subprocess.run(["skillshare", "uninstall", "--force", current_rel])
    if r1.returncode != 0:
        console.print("[red]Uninstall failed[/red]")
        raise typer.Exit(1)

    # --- reinstall ---
    install_cmd = ["skillshare", "install", install_url, "--name", new_name]
    if new_into:
        install_cmd += ["--into", new_into]
    r2 = subprocess.run(install_cmd)
    if r2.returncode != 0:
        console.print("[yellow]Reinstall failed, rolling back…[/yellow]")
        rollback_cmd = ["skillshare", "install", install_url, "--name", cur_name]
        if cur_into:
            rollback_cmd += ["--into", cur_into]
        rb = subprocess.run(rollback_cmd)
        if rb.returncode == 0:
            console.print("[green]✓ Rolled back to original name[/green]")
        else:
            restore_hint = f"skillshare install {install_url} --name {cur_name}"
            if cur_into:
                restore_hint += f" --into {cur_into}"
            console.print(Text.assemble(
                ("[red]Rollback also failed. Restore manually:[/red]\n  ", ""),
                (restore_hint, "dim"),
            ))
        raise typer.Exit(1)

    console.print(Text.assemble(("✓ ", "green"), "Renamed ", (current_rel, "bold"), " → ", (target_rel, "bold")))


def _check(ok: bool, label: str, detail: str) -> bool:
    mark = Text("✓ ", style="green") if ok else Text("✗ ", style="red")
    console.print(Text.assemble("  ", mark, label, "  ", (detail, "dim")))
    return ok


@app.command()
def doctor():
    """Check skillshare config, registered sources, and required tools."""
    errors = 0

    console.print("[bold]Checking environment[/bold]")
    if not _check(SKILLSHARE_CFG.exists(), "Config", str(SKILLSHARE_CFG)):
        errors += 1
        raise typer.Exit(1)

    if not _check(SOURCES_CFG.exists(), "Sources", str(SOURCES_CFG)):
        errors += 1

    current = _current_source()
    if not _check(Path(current).is_dir(), "Active source dir", current):
        errors += 1

    sources = _load_sources()
    name = _resolve_name(sources, current)
    _check(name is not None, "Active source registered", name or "(unregistered)")

    console.print()
    console.print("[bold]Checking sources[/bold]")
    for sname, spath in sources.items():
        p = Path(spath)
        if not _check(p.is_dir(), sname, spath):
            errors += 1
            continue
        skills = [
            d.name for d in p.iterdir() if d.is_dir() and (d / "SKILL.md").exists()
        ]
        console.print(Text(f"        {len(skills)} skill(s)", style="dim"))

    has_skillshare = shutil.which("skillshare") is not None

    console.print()
    console.print("[bold]Checking tools[/bold]")
    _check(has_skillshare, "skillshare", "required")

    console.print()
    if errors:
        console.print(f"[red]{errors} error(s) found[/red]")
        raise typer.Exit(1)
    else:
        console.print("[green]All checks passed[/green]")


if __name__ == "__main__":
    app()
