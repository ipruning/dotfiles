#!/usr/bin/env bash
set -euo pipefail

# Voice notification for agent blockers. Voice tuning lives here, not in prompts.

if [ $# -ne 1 ]; then
  echo "usage: notify-blocker <message>" >&2
  exit 1
fi

exec sag --voice Jessica --model-id eleven_v3 --lang en --speed 1.12 \
  --stability 0.5 --style 0.30 --similarity 0.84 --timeout 30s "$1"
