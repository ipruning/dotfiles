#!/usr/bin/env bash

set -euo pipefail
function logger() {
  local RED='\033[0;31m'
  local YELLOW='\033[1;33m'
  local GRAY='\033[0;90m'
  local NC='\033[0m'

  local message
  message=$1
  local loglevel
  loglevel=${2:-"INFO"}
  local loglevel_upper
  loglevel_upper=$(printf "%s" "$loglevel" | tr '[:lower:]' '[:upper:]')
  local timestamp
  timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

  local color
  color=$GRAY

  case "$loglevel_upper" in
  "ERROR")
    color=$RED
    ;;
  "WARN")
    color=$YELLOW
    ;;
  "INFO")
    if [ "${DRY_RUN:-}" = true ]; then
      color=$YELLOW
    else
      color=$GRAY
    fi
    ;;
  *)
    loglevel="INFO"
    loglevel_upper="INFO"
    color=$GRAY
    ;;
  esac

  printf "${color}[%s] [%s] %s${NC}\n" "$timestamp" "$loglevel_upper" "$message"
}
export -f logger

if ! command -v rust-parallel >/dev/null 2>&1; then
  logger "rust-parallel not found. Install: brew install rust-parallel" "ERROR"
  exit 1
fi

# Collect all update commands for parallel execution
parallel_cmds=()
if command -v brew >/dev/null 2>&1; then
  parallel_cmds+=('SECONDS=0; logger "Updating Homebrew..." && brew update && brew upgrade && brew cleanup && brew autoremove; logger "Homebrew done in ${SECONDS}s"')
fi
if command -v mise >/dev/null 2>&1; then
  parallel_cmds+=('SECONDS=0; logger "Updating mise..." && mise upgrade && mise prune --yes && mise reshim; logger "mise done in ${SECONDS}s"')
fi
if command -v gh >/dev/null 2>&1; then
  parallel_cmds+=('SECONDS=0; logger "Updating GitHub CLI extensions..." && gh extension upgrade --all; logger "GitHub CLI done in ${SECONDS}s"')
fi
if command -v tldr >/dev/null 2>&1; then
  parallel_cmds+=('SECONDS=0; logger "Updating tldr pages..." && tldr --update; logger "tldr done in ${SECONDS}s"')
fi
if command -v ya >/dev/null 2>&1; then
  parallel_cmds+=('SECONDS=0; logger "Updating ya packages..." && ya pkg upgrade; logger "ya done in ${SECONDS}s"')
fi
# curl -fsSL https://sprites.dev/install.sh | sh
if command -v sprite >/dev/null 2>&1; then
  parallel_cmds+=('SECONDS=0; logger "Updating Sprite..." && sprite upgrade; logger "Sprite done in ${SECONDS}s"')
else
  logger "sprite not found. Install: curl -fsSL https://sprites.dev/install.sh | sh" "WARN"
fi
# curl -fsSL https://ampcode.com/install.sh | bash
if command -v amp >/dev/null 2>&1; then
  parallel_cmds+=('SECONDS=0; logger "Updating Amp Code..." && amp update; logger "Amp done in ${SECONDS}s"')
else
  logger "amp not found. Install: curl -fsSL https://ampcode.com/install.sh | bash" "WARN"
fi
# curl -fsSL https://raw.githubusercontent.com/tigrisdata/cli/main/scripts/install.sh | sh
if command -v tigris >/dev/null 2>&1; then
  parallel_cmds+=('SECONDS=0; logger "Updating Tigris..." && tigris update; logger "Tigris done in ${SECONDS}s"')
else
  logger "tigris not found. Install: curl -fsSL https://raw.githubusercontent.com/tigrisdata/cli/main/scripts/install.sh | sh" "WARN"
fi
# skillshare update moved to mise run sync
if command -v pi >/dev/null 2>&1; then
  parallel_cmds+=('SECONDS=0; logger "Updating Pi Plugin..." && pi update; logger "Pi done in ${SECONDS}s"')
else
  logger "pi not found. Install: brew install pi-coding-agent" "WARN"
fi

if [[ ${#parallel_cmds[@]} -gt 0 ]]; then
  logger "Running ${#parallel_cmds[@]} updates in parallel..."
  printf '%s\n' "${parallel_cmds[@]}" | rust-parallel -s -k
fi

# backup moved to mise run sync
