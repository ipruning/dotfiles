#!/usr/bin/env bash

set -euo pipefail

usage() {
  cat <<'EOF'
Usage: repo-zip [output-dir]

Create a zip of the current Git repository that can be unzipped as a working
repo with .git history, current branch, tracked files, and non-ignored
untracked files.

output-dir defaults to the repository parent directory.
EOF
}

die() {
  echo "repo-zip: $*" >&2
  exit 1
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

if [[ $# -gt 1 ]]; then
  usage >&2
  exit 2
fi

command -v git >/dev/null 2>&1 || die "git not found"
command -v tar >/dev/null 2>&1 || die "tar not found"
command -v zip >/dev/null 2>&1 || die "zip not found"

repo_root="$(git rev-parse --show-toplevel 2>/dev/null)" ||
  die "not inside a Git repository"
repo_name="$(basename "$repo_root")"
repo_parent="$(dirname "$repo_root")"
output_dir="${1:-$repo_parent}"
mkdir -p "$output_dir"

branch="$(git -C "$repo_root" branch --show-current)"
if [[ -z "$branch" ]]; then
  branch="detached-$(git -C "$repo_root" rev-parse --short HEAD)"
fi

safe_branch="$(printf '%s' "$branch" | sed 's#[^A-Za-z0-9._-]#-#g')"
stamp="$(date +%Y%m%d-%H%M%S)"
output_path="$output_dir/${repo_name}-repo-${safe_branch}-${stamp}.zip"

tmpdir="$(mktemp -d)"
cleanup() {
  rm -rf "$tmpdir"
}
trap cleanup EXIT

bundle_path="$tmpdir/$repo_name.bundle"
clone_path="$tmpdir/$repo_name"

git -C "$repo_root" bundle create "$bundle_path" --all >/dev/null
git clone --quiet "$bundle_path" "$clone_path"

if git -C "$clone_path" rev-parse --verify --quiet "refs/heads/$branch" >/dev/null; then
  git -C "$clone_path" checkout --quiet "$branch"
else
  git -C "$clone_path" checkout --quiet "$(git -C "$repo_root" rev-parse HEAD)"
fi

(
  cd "$repo_root"

  git ls-files -z --deleted |
    while IFS= read -r -d '' path; do
      rm -f "$clone_path/$path"
    done

  git ls-files -z --cached --modified --others --exclude-standard |
    tar --null -T - -cf - |
    tar -xf - -C "$clone_path"
)

(
  cd "$tmpdir"
  zip -qr "$output_path" "$repo_name"
)

echo "$output_path"
