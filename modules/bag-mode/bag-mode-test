#!/bin/bash

set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
bag_mode="$script_dir/bag-mode"
readme="$script_dir/../../README.md"
test_root="$(mktemp -d -t bag-mode-test)"
test_home="$test_root/home"
fake_bin="$test_root/fake-bin"
fake_state="$test_root/fake-state"
control_dir="$test_root/Library/Application Support/bag-mode"
owner_file="$control_dir/service"
root_status_file="$control_dir/state"
brightness_pending_file="$control_dir/brightness-pending"
controller_reservation_dir="$control_dir/controller-reservation"
controller_reservation_file="$controller_reservation_dir/owner"
user_support_dir="$test_home/Library/Application Support/bag-mode"
controller_pid=""
foreground_pid=""
rejected_run_pid=""

cleanup() {
  if [[ -n "$controller_pid" ]]; then
    kill -KILL "$controller_pid" 2>/dev/null || true
  fi
  if [[ -n "$foreground_pid" ]]; then
    kill -KILL "$foreground_pid" 2>/dev/null || true
  fi
  if [[ -n "$rejected_run_pid" ]]; then
    kill -KILL "$rejected_run_pid" 2>/dev/null || true
  fi
  if [[ "${BAG_MODE_TEST_KEEP:-0}" == 1 ]]; then
    printf 'test artifacts kept: %s\n' "$test_root" >&2
  else
    rm -rf "$test_root"
  fi
}
trap cleanup EXIT

fail() {
  echo "FAIL: $*" >&2
  exit 1
}

wait_for() {
  local description="$1" command_text="$2" attempt
  for (( attempt = 0; attempt < 100; attempt++ )); do
    if /bin/bash -c "$command_text"; then
      return 0
    fi
    sleep 0.05
  done
  fail "timed out waiting for $description"
}

mkdir -p "$test_home" "$fake_bin" "$fake_state" "$control_dir" "$user_support_dir"
printf 'open\n' >"$fake_state/lid"
printf '0.700000\n' >"$fake_state/brightness"
printf '0\n' >"$fake_state/sleep-disabled"
printf '55\n' >"$fake_state/battery"
: >"$fake_state/calls"

cat >"$fake_bin/ioreg" <<'EOF'
#!/bin/bash
if [[ "$(sed -n '1p' "$BAG_MODE_FAKE_STATE/lid")" == closed ]]; then
  echo '"AppleClamshellState" = Yes'
else
  echo '"AppleClamshellState" = No'
fi
EOF

cat >"$fake_bin/brightness" <<'EOF'
#!/bin/bash
case "${1:-}" in
  -l)
    while [[ -e "$BAG_MODE_FAKE_STATE/block-brightness-query" ]]; do
      /bin/sleep 0.05
    done
    if [[ -e "$BAG_MODE_FAKE_STATE/display-unavailable" ]]; then
      echo 'display 1: external, active, awake, online, ID 0x2'
      exit 0
    fi
    echo 'display 0: main, active, awake, online, built-in, ID 0x1'
    printf 'display 0: brightness %s\n' "$(sed -n '1p' "$BAG_MODE_FAKE_STATE/brightness")"
    ;;
  -d)
    if [[ -e "$BAG_MODE_FAKE_STATE/fail-brightness" ]]; then
      echo 'injected brightness restore failure' >&2
      exit 7
    fi
    printf '%s\n' "$3" >"$BAG_MODE_FAKE_STATE/brightness"
    printf 'brightness %s\n' "$3" >>"$BAG_MODE_FAKE_STATE/calls"
    ;;
  *)
    exit 2
    ;;
esac
EOF

cat >"$fake_bin/pmset" <<'EOF'
#!/bin/bash
case "$*" in
  '-g batt')
    percentage="$(sed -n '1p' "$BAG_MODE_FAKE_STATE/battery")"
    printf "Now drawing from 'Battery Power'\n -InternalBattery-0 (id=1)\t%s%%; discharging; 2:00 remaining; present: true\n" "$percentage"
    ;;
  '-g custom')
    printf 'Battery Power:\n powermode            0\nAC Power:\n powermode            2\n'
    ;;
  '-g')
    printf 'System-wide power settings:\n SleepDisabled\t\t%s\n' "$(sed -n '1p' "$BAG_MODE_FAKE_STATE/sleep-disabled")"
    ;;
  '-a disablesleep 0'|'-a disablesleep 1')
    if [[ "$3" == 1 && -e "$BAG_MODE_FAKE_STATE/fail-start" ]]; then
      echo 'injected disablesleep startup failure' >&2
      exit 8
    fi
    if [[ "$3" == 0 && -e "$BAG_MODE_FAKE_STATE/fail-restore" ]]; then
      echo 'injected disablesleep restore failure' >&2
      exit 9
    fi
    printf '%s\n' "$3" >"$BAG_MODE_FAKE_STATE/sleep-disabled"
    printf 'pmset disablesleep %s\n' "$3" >>"$BAG_MODE_FAKE_STATE/calls"
    ;;
  '-b powermode 0'|'-b powermode 1')
    printf 'pmset powermode %s\n' "$3" >>"$BAG_MODE_FAKE_STATE/calls"
    ;;
  *)
    echo "unexpected pmset args: $*" >&2
    exit 2
    ;;
esac
EOF

cat >"$fake_bin/launchctl" <<'EOF'
#!/bin/bash
if [[ "${1:-}" == kickstart && -e "$BAG_MODE_FAKE_STATE/fail-kickstart" ]]; then
  echo 'injected launchctl kickstart failure' >&2
  exit 9
fi
if [[ "${1:-}" == bootout ]]; then
  if [[ -e "$BAG_MODE_FAKE_STATE/fail-bootout" ]]; then
    echo 'injected launchctl bootout failure' >&2
    exit 9
  fi
  if [[ "${2:-}" == system && ! -f "${3:-}" ]]; then
    exit 3
  fi
  : >"$BAG_MODE_FAKE_STATE/launchd-unloaded"
  exit 0
fi
if [[ "${1:-}" == bootstrap ]]; then
  if [[ -e "$BAG_MODE_FAKE_STATE/fail-bootstrap-once" ]]; then
    rm -f "$BAG_MODE_FAKE_STATE/fail-bootstrap-once"
    echo 'injected launchctl bootstrap failure' >&2
    exit 9
  fi
  rm -f "$BAG_MODE_FAKE_STATE/launchd-unloaded"
  exit 0
fi
if [[ "${1:-}" == print ]]; then
  if [[ -e "$BAG_MODE_FAKE_STATE/launchd-unloaded" ]]; then
    exit 3
  fi
  printf 'state = running\n'
  if [[ -s "$BAG_MODE_FAKE_STATE/launchd-pid" ]]; then
    printf 'pid = %s\n' "$(sed -n '1p' "$BAG_MODE_FAKE_STATE/launchd-pid")"
  fi
fi
exit 0
EOF

chmod +x "$fake_bin/ioreg" "$fake_bin/brightness" "$fake_bin/pmset" "$fake_bin/launchctl"

cat >"$fake_bin/brrr-send.sh" <<'EOF'
#!/bin/bash
printf '%s\n' "$*" >"$BAG_MODE_FAKE_STATE/notifier-call"
EOF
chmod +x "$fake_bin/brrr-send.sh"

test_env=(
  BAG_MODE_TESTING=1
  BAG_MODE_TEST_ROOT="$test_root"
  BAG_MODE_TEST_HOME="$test_home"
  BAG_MODE_RUN_USER="$(id -un)"
  BAG_MODE_BRIGHTNESS_BIN="$fake_bin/brightness"
  BAG_MODE_PMSET_BIN="$fake_bin/pmset"
  BAG_MODE_IOREG_BIN="$fake_bin/ioreg"
  BAG_MODE_LAUNCHCTL_BIN="$fake_bin/launchctl"
  BAG_MODE_FAKE_STATE="$fake_state"
  BAG_MODE_INTERVAL=0.05
  BAG_MODE_CLOSED_INTERVAL=0.05
  BAG_MODE_BATTERY_EVERY=1
  BAG_MODE_STOP_WAIT_ATTEMPTS=1
  BAG_MODE_STOP_WAIT_INTERVAL=0.01
  BAG_MODE_START_WAIT_ATTEMPTS=1
  BAG_MODE_START_WAIT_INTERVAL=0.01
  BAG_MODE_NOTIFY_TIMEOUT=1
)

: >"$fake_state/launchd-unloaded"
env "${test_env[@]}" CI=1 "$bag_mode" doctor --strict --json >"$test_root/preinstall-doctor.json"
env "${test_env[@]}" CI=1 "$bag_mode" status --json >"$test_root/preinstall-status.json"
rm -f "$fake_state/launchd-unloaded"
mise exec -- jq -e 'select(.ok == true and .installation.binary == false and .installation.version_matches == null and .installation.controller == false and .installation.controller_version_matches == null and .installation.plist == false and .installation.launchd_loaded == false)' "$test_root/preinstall-doctor.json" >/dev/null \
  || fail 'preinstall doctor did not distinguish absent installation from a version mismatch'
mise exec -- jq -e 'select(.installed == false and .launchd_loaded == false and .enabled == false and .phase == "stopped" and .recovery_required == false and .brightness_pending == false and .controller.alive == false)' "$test_root/preinstall-status.json" >/dev/null \
  || fail 'preinstall status did not report a clean stopped lifecycle'

env "${test_env[@]}" CI=1 "$bag_mode" install --dry-run >"$test_root/install-dry-run.txt"
rg -q '^ready: true$' "$test_root/install-dry-run.txt" || fail 'install dry-run did not report readiness'
env "${test_env[@]}" "$bag_mode" install >/dev/null
runtime_bin="$test_root/usr/local/bin/bag-mode"
runtime_controller="$test_root/Library/PrivilegedHelperTools/dev.bag-mode.controller"
runtime_plist="$test_root/Library/LaunchDaemons/dev.bag-mode.daemon.plist"

# macOS can SIGKILL execve of a freshly rewritten temporary script inode. Keep
# the harness focused on shell behavior by opening reinstalled fixtures through
# the stable system interpreter; production execution remains unchanged.
env() {
  local -a environment_args=()
  if [[ "${1:-}" != *=* ]]; then
    command env "$@"
    return
  fi
  while [[ "${1:-}" == *=* ]]; do
    environment_args+=("$1")
    shift
  done
  case "${1:-}" in
    "$runtime_bin"|"$runtime_controller") command env "${environment_args[@]}" /bin/bash "$@" ;;
    *) command env "${environment_args[@]}" "$@" ;;
  esac
}

[[ -x "$runtime_bin" && -x "$runtime_controller" ]] || fail 'install did not create the CLI and privileged controller copies'
plutil -lint "$runtime_plist" >/dev/null || fail 'install generated an invalid plist'
plutil -extract ProgramArguments.0 raw "$runtime_plist" | rg -Fxq "$runtime_controller" \
  || fail 'LaunchDaemon did not use the root-only controller path'
env "${test_env[@]}" "$runtime_bin" install >"$test_root/idempotent-install.out"
rg -q '^installed_controller: ' "$test_root/idempotent-install.out" || fail 'installed executable could not reinstall itself'

printf '# prior cli bytes\n' >>"$runtime_bin"
printf '# prior controller bytes\n' >>"$runtime_controller"
printf '<!-- prior plist bytes -->\n' >>"$runtime_plist"
chmod 0700 "$runtime_bin"
chmod 0710 "$runtime_controller"
chmod 0600 "$runtime_plist"
cp "$runtime_bin" "$test_root/prior-cli"
cp "$runtime_controller" "$test_root/prior-controller"
cp "$runtime_plist" "$test_root/prior-plist"
: >"$fake_state/fail-bootstrap-once"
exit_code=0
env "${test_env[@]}" "$bag_mode" install >"$test_root/bootstrap-failed-install.out" 2>"$test_root/bootstrap-failed-install.err" || exit_code=$?
[[ "$exit_code" == 1 ]] || fail 'injected bootstrap failure returned success'
[[ ! -s "$test_root/bootstrap-failed-install.out" ]] || fail 'failed install printed installation success'
cmp -s "$test_root/prior-cli" "$runtime_bin" || fail 'failed install did not restore byte-identical prior CLI'
cmp -s "$test_root/prior-controller" "$runtime_controller" || fail 'failed install did not restore byte-identical prior controller'
cmp -s "$test_root/prior-plist" "$runtime_plist" || fail 'failed install did not restore byte-identical prior plist'
[[ "$(stat -f '%Lp' "$runtime_bin")" == 700 \
  && "$(stat -f '%Lp' "$runtime_controller")" == 710 \
  && "$(stat -f '%Lp' "$runtime_plist")" == 600 ]] \
  || fail 'failed install did not restore prior managed-file modes'
env "${test_env[@]}" "$fake_bin/launchctl" print system/dev.bag-mode.daemon >/dev/null \
  || fail 'failed install did not restore the prior loaded state'
rg -q 'prior installation and LaunchDaemon state restored' "$test_root/bootstrap-failed-install.err" \
  || fail 'failed install did not report successful rollback'

: >"$fake_state/fail-bootstrap-once"
: >"$fake_state/fail-restore"
exit_code=0
env "${test_env[@]}" "$runtime_bin" upgrade \
  >"$test_root/rollback-failed-upgrade.out" 2>"$test_root/rollback-failed-upgrade.err" || exit_code=$?
[[ "$exit_code" == 1 ]] || fail 'upgrade with incomplete rollback returned success'
rg -q 'rollback was incomplete; prior service restart was not attempted' "$test_root/rollback-failed-upgrade.err" \
  || fail 'upgrade did not distinguish an incomplete install rollback'
if rg -q 'prior installation state restored' "$test_root/rollback-failed-upgrade.err"; then
  fail 'upgrade falsely claimed restoration after rollback failure'
fi
backup_dir="$(sed -n 's/.*backups kept at //p' "$test_root/rollback-failed-upgrade.err" | tail -1)"
[[ -n "$backup_dir" && -d "$backup_dir" && -f "$backup_dir/cli" \
  && -f "$backup_dir/controller" && -f "$backup_dir/plist" ]] \
  || fail 'incomplete install rollback discarded its recovery backup'
cp -p "$test_root/prior-cli" "$runtime_bin.replacement"
cp -p "$test_root/prior-controller" "$runtime_controller.replacement"
cp -p "$test_root/prior-plist" "$runtime_plist.replacement"
mv -f "$runtime_bin.replacement" "$runtime_bin"
mv -f "$runtime_controller.replacement" "$runtime_controller"
mv -f "$runtime_plist.replacement" "$runtime_plist"
rm -rf "$backup_dir"

rm -f "$runtime_bin"
ln -s "$bag_mode" "$runtime_bin"
: >"$fake_state/fail-bootstrap-once"
exit_code=0
env "${test_env[@]}" "$bag_mode" install \
  >"$test_root/symlink-rollback.out" 2>"$test_root/symlink-rollback.err" || exit_code=$?
[[ "$exit_code" == 1 && -L "$runtime_bin" \
  && "$(readlink "$runtime_bin")" == "$bag_mode" ]] \
  || fail 'failed install did not restore the prior managed-path symlink'
env "${test_env[@]}" "$runtime_bin" install >"$test_root/symlink-install.out"
[[ -f "$runtime_bin" && ! -L "$runtime_bin" ]] || fail 'install left a symlink as the privileged controller executable'
[[ "$(stat -f '%Lp' "$runtime_bin")" == 755 ]] || fail 'installed controller executable remained group- or user-writable'
[[ -f "$runtime_controller" && ! -L "$runtime_controller" && "$(stat -f '%Lp' "$runtime_controller")" == 755 ]] \
  || fail 'root-only controller copy was missing or had an unsafe mode'
: >"$fake_state/fail-kickstart"
exit_code=0
env "${test_env[@]}" "$runtime_bin" start >"$test_root/kickstart-failed.out" 2>"$test_root/kickstart-failed.err" || exit_code=$?
rm -f "$fake_state/fail-kickstart"
[[ "$exit_code" == 1 ]] || fail 'kickstart failure returned success'
[[ ! -e "$control_dir/enabled" ]] || fail 'kickstart failure left the service enabled'
rg -q 'service disabled' "$test_root/kickstart-failed.err" || fail 'kickstart failure did not explain rollback'
exit_code=0
env "${test_env[@]}" "$runtime_bin" start >"$test_root/readiness-failed.out" 2>"$test_root/readiness-failed.err" || exit_code=$?
[[ "$exit_code" == 1 ]] || fail 'readiness timeout returned success'
[[ ! -e "$control_dir/enabled" ]] || fail 'readiness timeout left the service enabled'
rg -q 'service disabled' "$test_root/readiness-failed.err" || fail 'readiness timeout did not explain rollback'
: >"$control_dir/enabled"
mkdir "$controller_reservation_dir"
{
  printf 'session_id\tstale-enabled-reservation\n'
  printf 'controller_mode\tlaunchd\n'
  printf 'pid\t\n'
  printf 'executable\t\n'
} >"$controller_reservation_file"
chmod 000 "$control_dir/config"
{
  printf 'last_event\tstarted\n'
  printf 'pid\t%s\n' "$$"
} >"$user_support_dir/state"
printf '%s\n' "$PPID" >"$fake_state/launchd-pid"
exit_code=0
env "${test_env[@]}" "$runtime_bin" start >"$test_root/stale-enabled.out" 2>"$test_root/stale-enabled.err" || exit_code=$?
[[ "$exit_code" == 1 ]] || fail 'stale enabled marker returned success'
[[ ! -e "$control_dir/enabled" ]] || fail 'idempotent readiness timeout kept a stale enabled marker'
[[ ! -e "$controller_reservation_dir" ]] || fail 'idempotent readiness timeout kept a root-owned controller reservation'
chmod 0600 "$control_dir/config"
rm -f "$user_support_dir/state" "$fake_state/launchd-pid"
env "${test_env[@]}" CI=1 "$runtime_bin" install --dry-run >"$test_root/post-start-failure-install.txt"
rg -q '^ready: true$' "$test_root/post-start-failure-install.txt" || fail 'failed start left state that blocked installation'
if rg -q 'tmux|BRRR_HELPER' "$runtime_bin" "$runtime_controller" "$runtime_plist" || rg -q '\.agents/skills|skillshare' "$runtime_plist"; then
  fail 'installed controller retained a tmux or Skillshare runtime dependency'
fi
env "${test_env[@]}" CI=1 "$runtime_bin" >"$test_root/top-help.txt"
rg -q '^Usage: bag-mode COMMAND \[OPTIONS\]$' "$test_root/top-help.txt" || fail 'no-argument invocation did not show the command map'
rg -q '^Exit status:$' "$test_root/top-help.txt" || fail 'top-level help did not disclose the exit-code contract'
env "${test_env[@]}" CI=1 "$runtime_bin" status --help >"$test_root/status-help.txt"
for lifecycle_phase in stopped starting running recovery_required; do
  rg -q "^[[:space:]]*$lifecycle_phase" "$test_root/status-help.txt" || fail "status help omitted lifecycle phase $lifecycle_phase"
done
rg -q '^Brightness pending is independent of lifecycle recovery:' "$test_root/status-help.txt" || fail 'status help conflated pending brightness with lifecycle recovery'
if rg -ni '\b(dirty|unclean)\b' "$runtime_bin" "$readme"; then
  fail 'CLI or README retained rejected recovery terminology'
fi
exit_code=0
env "${test_env[@]}" CI=1 "$runtime_bin" agent-guide >"$test_root/agent-guide.out" 2>"$test_root/agent-guide.err" || exit_code=$?
[[ "$exit_code" == 2 ]] || fail 'removed agent-guide command did not return the usage status'
exit_code=0
env "${test_env[@]}" CI=1 "$runtime_bin" nonsense >"$test_root/direct-bogus.out" 2>"$test_root/direct-bogus.err" || exit_code=$?
[[ "$exit_code" == 2 ]] || fail 'unknown top-level command did not return the usage status'
rg -q '^bag-mode: unknown command: nonsense$' "$test_root/direct-bogus.err" || fail 'unknown top-level command did not identify the typo'
env "${test_env[@]}" CI=1 "$runtime_bin" install --help >"$test_root/install-help.txt"
rg -q '^Usage: bag-mode install \[--dry-run\]$' "$test_root/install-help.txt" || fail 'install help was not scoped or safe'
rg -q '^Recommended installation flow:$' "$test_root/install-help.txt" || fail 'install help did not disclose the installation workflow'
exit_code=0
env "${test_env[@]}" CI=1 "$runtime_bin" help nonsense >"$test_root/help-bogus.out" 2>"$test_root/help-bogus.err" || exit_code=$?
[[ "$exit_code" == 2 ]] || fail 'help for an unknown command returned success'
mv "$runtime_plist" "$runtime_plist.missing"
exit_code=0
env "${test_env[@]}" CI=1 "$runtime_bin" doctor --strict --json >"$test_root/doctor-missing-plist.json" || exit_code=$?
[[ "$exit_code" == 1 ]] || fail 'strict doctor accepted an installed service with a missing plist'
mise exec -- jq -e 'select(.ok == false and .installation.plist == false and .problems >= 1)' "$test_root/doctor-missing-plist.json" >/dev/null \
  || fail 'strict doctor did not describe the missing plist failure'
mv "$runtime_plist.missing" "$runtime_plist"
mv "$runtime_controller" "$runtime_controller.missing"
exit_code=0
env "${test_env[@]}" CI=1 "$runtime_bin" doctor --strict --json >"$test_root/doctor-missing-controller.json" || exit_code=$?
[[ "$exit_code" == 1 ]] || fail 'strict doctor accepted an installation with no privileged controller'
mise exec -- jq -e 'select(.ok == false and .installation.binary == true and .installation.controller == false and .problems >= 1)' "$test_root/doctor-missing-controller.json" >/dev/null \
  || fail 'strict doctor did not describe the missing controller failure'
mv "$runtime_controller.missing" "$runtime_controller"
: >"$fake_state/launchd-unloaded"
exit_code=0
env "${test_env[@]}" CI=1 "$runtime_bin" doctor --strict --json >"$test_root/doctor-unloaded.json" || exit_code=$?
rm -f "$fake_state/launchd-unloaded"
[[ "$exit_code" == 1 ]] || fail 'strict doctor accepted an installed but unloaded service'
mise exec -- jq -e 'select(.ok == false and .installation.binary == true and .installation.controller == true and .installation.plist == true and .installation.launchd_loaded == false and .problems >= 1)' "$test_root/doctor-unloaded.json" >/dev/null \
  || fail 'strict doctor did not describe the unloaded service failure'
env "${test_env[@]}" CI=1 "$runtime_bin" doctor --strict --json >"$test_root/doctor.json"
mise exec -- jq -e . "$test_root/doctor.json" >/dev/null || fail 'doctor JSON was invalid'
rg -q '"ok":true' "$test_root/doctor.json" || fail 'strict doctor JSON did not report success'
exit_code=0
env "${test_env[@]}" CI=1 "$runtime_bin" doctor --bogus >"$test_root/bogus.out" 2>"$test_root/bogus.err" || exit_code=$?
[[ "$exit_code" == 2 ]] || fail "unknown doctor option exited $exit_code instead of 2"
exit_code=0
env "${test_env[@]}" CI=1 "$runtime_bin" uninstall >"$test_root/uninstall.out" 2>"$test_root/uninstall.err" || exit_code=$?
[[ "$exit_code" == 2 && -x "$runtime_bin" ]] || fail 'uninstall did not require explicit --yes'
exit_code=0
env "${test_env[@]}" CI=1 "$runtime_bin" logs --bogus >"$test_root/logs-bogus.out" 2>"$test_root/logs-bogus.err" || exit_code=$?
[[ "$exit_code" == 2 ]] || fail "unknown logs option exited $exit_code instead of 2"

env "${test_env[@]}" "$runtime_bin" notifier install-brrr >"$test_root/notifier-builtin-install.out"
BRRR_SECRET=test-secret /bin/bash "$user_support_dir/notifiers/brrr-send" \
  --title 'dry run' --subtitle 'bag-mode · test host' --message 'built in' \
  --thread-id bag-mode --expiration-date '2026-07-13T18:00:00Z' --dry-run \
  >"$test_root/notifier-builtin-dry-run.out"
rg -q '^auth_mode=bearer$' "$test_root/notifier-builtin-dry-run.out" \
  || fail 'built-in brrr sender did not validate its configured delivery path'
rg -q '"thread_id":"bag-mode"' "$test_root/notifier-builtin-dry-run.out" \
  || fail 'built-in brrr sender did not preserve the notification payload'
rg -q '"subtitle":"bag-mode · test host"' "$test_root/notifier-builtin-dry-run.out" \
  || fail 'built-in brrr sender did not preserve the notification subtitle'
rg -q '"expiration_date":"2026-07-13T18:00:00Z"' "$test_root/notifier-builtin-dry-run.out" \
  || fail 'built-in brrr sender did not preserve the expiration date'
stub_home="$test_root/stub-env-home"
mkdir -p "$stub_home/.config/brrr" "$stub_home/.config/notify"
printf '# stub without a secret\n' >"$stub_home/.config/brrr/env"
printf 'export BRRR_SECRET=from-second-file\n' >"$stub_home/.config/notify/brrr.env"
env -u BRRR_SECRET HOME="$stub_home" /bin/bash "$user_support_dir/notifiers/brrr-send" \
  --title 'fallthrough' --message 'stub first file' --dry-run \
  >"$test_root/notifier-env-fallthrough.out"
rg -q '^auth_mode=bearer$' "$test_root/notifier-env-fallthrough.out" \
  || fail 'a secretless readable env file masked the later brrr env candidate'

proxy_marker="$test_root/shelley.json"
proxy_sender="$test_root/brrr-send-proxy-test"
sed "s#/exe.dev/shelley.json#$proxy_marker#g" "$user_support_dir/notifiers/brrr-send" >"$proxy_sender"
chmod +x "$proxy_sender"
: >"$proxy_marker"
BRRR_SECRET=test-secret /bin/bash "$proxy_sender" \
  --title 'auth precedence' --message 'explicit bearer' --dry-run \
  >"$test_root/notifier-builtin-proxy-dry-run.out"
rg -q '^auth_mode=bearer$' "$test_root/notifier-builtin-proxy-dry-run.out" \
  || fail 'explicit brrr secret did not take precedence over the exe.dev proxy'
env "${test_env[@]}" "$runtime_bin" notifier install-brrr "$fake_bin/brrr-send.sh" >/dev/null
rm -f "$fake_bin/brrr-send.sh"
env "${test_env[@]}" "$user_support_dir/notifier" \
  --event test --level passive --title 'test title' --message 'test message'
rg -q -- '--title .*: test title --subtitle bag-mode · macOS power safety --message test message --thread-id bag-mode --interruption-level passive' "$fake_state/notifier-call" \
  || fail 'installed brrr adapter did not preserve the generic notifier contract'
